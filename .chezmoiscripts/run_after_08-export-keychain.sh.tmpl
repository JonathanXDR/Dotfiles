#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

# Re-export managed secrets from the dotfiles keychain to iCloud Drive after
# every apply. Delegates to the secrets:export zsh function, the single
# implementation of the export logic. It enumerates the keychain (the source
# of truth) and skips the write when nothing changed.

KEYCHAIN_NAME={{ .keychain_name | quote }}
KEYCHAIN="$HOME/Library/Keychains/${KEYCHAIN_NAME}.keychain-db"
TOKENS_FILE="{{ .icloud_secrets }}/.keychain/tokens"

# The tokens-file gate avoids seeding the iCloud path before iCloud has synced
# it down. The very first backup is created by an interactive secrets:export.
[[ -f "$KEYCHAIN" && -f "$TOKENS_FILE" && -f "$HOME/.functions" ]] || exit 0

# A failed export must not abort the apply (this script runs before 09), so
# problems surface as a warning next to the function's own error output.
SECRETS_TOKENS_FILE="$TOKENS_FILE" \
SECRETS_KEYCHAIN_NAME="$KEYCHAIN_NAME" \
  zsh -c 'source "$HOME/.functions" && secrets:export' \
  || _log warning "Skipped tokens file update (see errors above)"
