#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

# Re-export managed secrets from the login keychain to iCloud Drive after every apply.

TOKENS_FILE="{{ .icloud_secrets }}/.keychain/tokens"

[[ -f "$TOKENS_FILE" ]] || exit 0

tmpfile="$(mktemp)"
trap 'rm -f "$tmpfile"' EXIT

# Preserve header comments
grep '^#' "$TOKENS_FILE" > "$tmpfile" 2>/dev/null || true

changed=false

while IFS=: read -r service account old_password; do
  [[ -z "$service" || "$service" == \#* ]] && continue

  password="$(security find-generic-password -s "$service" -a "$account" -w 2>/dev/null)" || true
  if [[ -n "$password" ]]; then
    echo "$service:$account:$password" >> "$tmpfile"
    [[ "$password" != "$old_password" ]] && changed=true
  else
    echo "$service:$account:$old_password" >> "$tmpfile"
  fi
done < "$TOKENS_FILE"

if [[ "$changed" == true ]]; then
  mv "$tmpfile" "$TOKENS_FILE"
  _log success "Keychain -> iCloud Drive: tokens file updated."
fi
