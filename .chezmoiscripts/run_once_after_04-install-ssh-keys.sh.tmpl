#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

ICLOUD_SSH="{{ .icloud_secrets }}/.ssh"
TARGET_DIR="${HOME}/.ssh"

_require_icloud_dir "$ICLOUD_SSH" "SSH" || exit 0

mkdir -p "$TARGET_DIR"

for file in "$ICLOUD_SSH"/*; do
  [[ -f "$file" ]] || continue
  filename="$(basename "$file")"
  cp "$file" "$TARGET_DIR/$filename"

  if [[ "$filename" == *.pub ]] || [[ "$filename" == "config" ]] || [[ "$filename" == "known_hosts" ]]; then
    chmod 644 "$TARGET_DIR/$filename"
  else
    chmod 600 "$TARGET_DIR/$filename"
  fi

  _log success "Installed: $filename"
done

_log info "SSH keys installed to $TARGET_DIR"
