#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

ICLOUD_GPG="{{ .icloud_secrets }}/.gnupg"
TARGET_DIR="${HOME}/.gnupg"

_require_icloud_dir "$ICLOUD_GPG" "GPG" || exit 0

mkdir -p "$TARGET_DIR"
chmod 700 "$TARGET_DIR"

rsync -a \
  --exclude='S.gpg-agent*' \
  --exclude='S.keyboxd' \
  --exclude='S.scdaemon' \
  --exclude='*.lock' \
  --exclude='.DS_Store' \
  "$ICLOUD_GPG/" "$TARGET_DIR/"

find "$TARGET_DIR" -type d -exec chmod 700 {} \;
find "$TARGET_DIR" -type f -exec chmod 600 {} \;

_log success "GPG keys installed to $TARGET_DIR"
