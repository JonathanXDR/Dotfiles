#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

# Plist content hash (triggers re-run when plist changes):
# {{ include "Library/LaunchAgents/local.proxy-watchd.plist.tmpl" | sha256sum }}

PLIST_LABEL="local.proxy-watchd"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_LABEL}.plist"

{{ if eq .machine_type "work" -}}
if [[ ! -f "${PLIST_PATH}" ]]; then
  _log error "Missing plist (${PLIST_PATH}), skipping LaunchAgent bootstrap"
  exit 0
fi

mkdir -p "${HOME}/.cache"

launchctl bootout "gui/$(id -u)/${PLIST_LABEL}" 2>/dev/null || true
launchctl bootstrap "gui/$(id -u)" "${PLIST_PATH}"

_log success "Bootstrapped proxy LaunchAgent (${PLIST_LABEL})"
{{ else -}}
# Not a work machine, so ensure agent is not loaded.
launchctl bootout "gui/$(id -u)/${PLIST_LABEL}" 2>/dev/null || true
{{ end -}}
