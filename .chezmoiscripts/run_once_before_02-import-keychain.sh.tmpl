#!/bin/bash
set -euo pipefail
{{ template "shell-helpers" . }}

# Import tokens from the iCloud Drive backup into the dedicated dotfiles keychain.
# Runs once before templates render, ensuring keyring calls succeed on a fresh machine.
# Delegates to the secrets zsh functions (sourced from the chezmoi source dir,
# since ~/.functions is not symlinked yet on first apply): the keychain is
# created even when there is no backup to import, because run_before_00 and the
# secret-reading templates rely on it existing after this script.

export SECRETS_TOKENS_FILE="{{ .icloud_secrets }}/.keychain/tokens"
export SECRETS_KEYCHAIN_NAME={{ .keychain_name | quote }}
export SECRETS_KEYCHAIN_LOOKUP_FIELD={{ .keychain_lookup_field | quote }}
export SECRETS_KEYCHAIN_PASSWORD={{ if hasKey . "keychain_password" }}{{ .keychain_password | quote }}{{ else }}""{{ end }}
export DOTFILES_SOURCE={{ .chezmoi.sourceDir | quote }}

zsh -c 'source "$DOTFILES_SOURCE/dot_functions" && _secrets:ensure-keychain'

if [[ ! -f "$SECRETS_TOKENS_FILE" ]]; then
  _log warning "Skipped import (tokens file not found at $SECRETS_TOKENS_FILE)"
  _log info "Add tokens manually via 'secret:set <id> <account> <where> <kind> [comment]'"
  exit 0
fi

_ensure_icloud "$SECRETS_TOKENS_FILE" || true

zsh -c 'source "$DOTFILES_SOURCE/dot_functions" && secrets:import' \
  || _log warning "Detected entries needing attention (run secrets:import after apply)"
