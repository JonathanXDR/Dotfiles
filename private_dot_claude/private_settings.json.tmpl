    "vercel@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "nuxt-seo-claude-plugins": {
      "autoUpdate": true,
      "source": {
        "repo": "nuxt-seo-pro/claude-plugins",
        "source": "github"
      }
    }
  },
  "hooks": {
{{- $events := list
      "ConfigChange"
      "CwdChanged"
      "Elicitation"
      "ElicitationResult"
      "InstructionsLoaded"
      "Notification"
      "PermissionDenied"
      "PermissionRequest"
      "PostCompact"
      "PostToolUse"
      "PostToolUseFailure"
      "PreCompact"
      "PreToolUse"
      "SessionEnd"
      "SessionStart"
      "Stop"
      "StopFailure"
      "SubagentStart"
      "SubagentStop"
      "TaskCompleted"
      "TeammateIdle"
      "UserPromptSubmit" -}}
{{- $gk := printf "%s/Library/Application Support/GitKrakenCLI/gk" .chezmoi.homeDir -}}
{{- range $i, $event := $events }}
    "{{ $event }}": [
      {
        "hooks": [
          {
            "command": {{ printf "\"%s\" ai hook run --host claude-code" $gk | quote }},
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]{{ if lt (add $i 1) (len $events) }},{{ end }}
{{- end }}
  },
  "includeCoAuthoredBy": false,
  "skipDangerousModePermissionPrompt": true
}
