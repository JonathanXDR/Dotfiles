{{ if eq .machine_type "work" -}}
#!/bin/bash
set -euo pipefail

ICLOUD_SSL="{{ .icloud_secrets }}/ssl"
TARGET_DIR="${HOME}/.ssl"

if [[ ! -d "$ICLOUD_SSL" ]]; then
  echo "iCloud SSL directory not found: $ICLOUD_SSL"
  echo "Skipping SSL bundle installation."
  echo "You can regenerate it later with: ssl:bundle"
  exit 0
fi

# Ensure iCloud files are downloaded
if command -v brctl &>/dev/null; then
  brctl download "$ICLOUD_SSL" 2>/dev/null || true
  sleep 2
fi

mkdir -p "$TARGET_DIR"

for file in "$ICLOUD_SSL"/*; do
  [[ -f "$file" ]] || continue
  filename="$(basename "$file")"
  cp "$file" "$TARGET_DIR/$filename"
  chmod 600 "$TARGET_DIR/$filename"
  echo "Installed SSL file: $filename"
done

echo "SSL bundle installed to $TARGET_DIR"
{{ end -}}
