# Shell completions and autocompletion setup

# Homebrew prefix (cached for all plugin lookups below)
local brew_share=""
if cmd:exists brew; then
  local brew_prefix
  brew_prefix="$(brew --prefix)"
  brew_share="${brew_prefix}/share"

  FPATH="${brew_share}/zsh-completions:$FPATH"

  autoload -Uz compinit
  if [[ -n ~/.zcompdump(N.mh-24) ]]; then
    compinit -C
  else
    compinit
  fi
fi

# Bun completions
[[ -s "${HOME}/.bun/_bun" ]] && source "${HOME}/.bun/_bun"

# Angular CLI autocompletion (cached — regenerated once per day)
if cmd:exists ng; then
  local ng_cache="${HOME}/.cache/daily/ng-completions.zsh"
  local -a fresh=( ${ng_cache}(N.mh-24) )
  if (( ! ${#fresh} )); then
    mkdir -p "${ng_cache:h}"
    ng completion script > "$ng_cache" 2>/dev/null
  fi
  [[ -f "$ng_cache" ]] && source "$ng_cache"
fi

# zsh plugins (guard each in case plugin is uninstalled)
if [[ -n "$brew_share" ]]; then
  [[ -f "${brew_share}/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] \
    && source "${brew_share}/zsh-autosuggestions/zsh-autosuggestions.zsh"

  [[ -f "${brew_share}/zsh-autocomplete/zsh-autocomplete.plugin.zsh" ]] \
    && source "${brew_share}/zsh-autocomplete/zsh-autocomplete.plugin.zsh"
fi

# Kiro CLI compatibility:
# Kiro renders inline suggestions via figterm (terminal-level overlay), which
# gets wiped whenever zsh-autocomplete redraws the screen. Disable the
# as-you-type completion menu to prevent it from overwriting Kiro's suggestions.
if (( $+functions[.autocomplete:async:complete] )); then
  .autocomplete:async:complete() { return 0 }
fi

# Shift+Tab triggers zsh-autocomplete's menu as a manual fallback, since Tab
# is reserved by Kiro CLI. Clears ghost text first to prevent it from being
# committed into the buffer alongside the selected completion.
if (( $+widgets[menu-select] )); then
  _zsh_autocomplete_fallback() {
    unset POSTDISPLAY
    zle menu-select
  }

  zle -N _zsh_autocomplete_fallback
  bindkey '\e[Z' _zsh_autocomplete_fallback
fi

# Syntax highlighting (must be sourced near end of .zshrc / completions)
if [[ -n "$brew_share" ]]; then
  [[ -f "${brew_share}/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] \
    && source "${brew_share}/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

  [[ -f "${brew_share}/zsh-history-substring-search/zsh-history-substring-search.zsh" ]] \
    && source "${brew_share}/zsh-history-substring-search/zsh-history-substring-search.zsh"
fi
