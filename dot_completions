#!/usr/bin/env zsh
# Shell completions and autocompletion setup

# Homebrew zsh-completions
if cmd:exists brew; then
  FPATH=$(brew --prefix)/share/zsh-completions:$FPATH

  autoload -Uz compinit
  compinit
fi

# bun completions
[ -s "/Users/$USER/.bun/_bun" ] && source "/Users/$USER/.bun/_bun"

# NVM bash completion
if [[ -s "$NVM_DIR/bash_completion" ]]; then
  source "$NVM_DIR/bash_completion"
elif [[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ]]; then
  source "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
fi

# Angular CLI autocompletion
source <(ng completion script)

# zsh plugins
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-autocomplete/zsh-autocomplete.plugin.zsh

# Kiro CLI compatibility:
# Kiro renders inline suggestions via figterm (terminal-level overlay), which
# gets wiped whenever zsh-autocomplete redraws the screen. Disable the
# as-you-type completion menu to prevent it from overwriting Kiro's suggestions.
.autocomplete:async:complete() { return 0 }

# Shift+Tab triggers zsh-autocomplete's menu as a manual fallback, since Tab
# is reserved by Kiro CLI.  Clears ghost text first to prevent it from being
# committed into the buffer alongside the selected completion.
_zsh_autocomplete_fallback() {
  unset POSTDISPLAY
  zle menu-select
}

zle -N _zsh_autocomplete_fallback
bindkey '\e[Z' _zsh_autocomplete_fallback

source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
