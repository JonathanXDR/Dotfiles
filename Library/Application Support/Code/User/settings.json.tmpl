  },
  "[shellscript]": {
    "editor.defaultFormatter": "mads-hartmann.bash-ide-vscode"
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "[svg]": {
    "editor.defaultFormatter": "jock.svg"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[vue]": {
    "editor.defaultFormatter": "rvest.vs-code-prettier-eslint"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "amazonQ.importRecommendationForInlineCodeSuggestions": false,
  "amazonQ.shareContentWithAWS": false,
  "amazonQ.showCodeWithReferences": false,
  "amazonQ.suppressPrompts": {
    "amazonQChatDisclaimer": true,
    "amazonQChatPairProgramming": true,
    "amazonQSessionConfigurationMessage": true
  },
  "amazonQ.telemetry": false,
  "application.shellEnvironmentResolutionTimeout": 30,
  "aws.cloudformation.telemetry.enabled": false,
  "claudeCode.preferredLocation": "panel",
  "console-ninja.featureSet": "Community",
  "cSpell.diagnosticLevel": "Hint",
  "database-client.autoSync": true,
  "diffEditor.experimental.showEmptyDecorations": false,
  "docker.extension.enableComposeLanguageServer": false,
  "editor.accessibilitySupport": "off",
  "editor.autoClosingBrackets": "beforeWhitespace",
  "editor.autoClosingComments": "beforeWhitespace",
  "editor.autoClosingDelete": "auto",
  "editor.autoClosingOvertype": "auto",
  "editor.autoClosingQuotes": "beforeWhitespace",
  "editor.autoIndent": "full",
  "editor.autoIndentOnPaste": true,
  "editor.autoIndentOnPasteWithinString": true,
  "editor.autoSurround": "brackets",
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit",
    "source.organizeImports": "explicit",
    "source.sort.json": "explicit",
    "source.sortMembers": "explicit"
  },
  "editor.foldingImportsByDefault": true,
  "editor.fontWeight": "normal",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.guides.indentation": false,
  "editor.linkedEditing": true,
  "editor.matchBrackets": "never",
  "editor.minimap.enabled": true,
  "editor.renderWhitespace": "all",
  "editor.showDeprecated": true,
  "editor.stickyScroll.enabled": false,
  "editor.tabSize": 2,
  "editor.unicodeHighlight.includeComments": true,
  "emmet.variables": {
    "lang": "en"
  },
  "eslint.codeAction.disableRuleComment": {
    "commentStyle": "line",
    "enable": true,
    "location": "separateLine"
  },
  "eslint.codeActionsOnSave.mode": "all",
  "eslint.enable": true,
  "eslint.format.enable": true,
  "eslint.lintTask.options": "--flag unstable_ts_config",
  "eslint.options": {
    "flags": [
      "unstable_ts_config"
    ]
  },
  "eslint.run": "onSave",
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "files.associations": {
    "*.mdx": "markdown"
  },
  "files.exclude": {
    "**/.claude/": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true,
    "AGENTS.md": true,
    "CLAUDE.md": true
  },
  "files.watcherExclude": {
    "**/.ammonite": true,
    "**/.bloop": true,
    "**/.metals": true,
    "**/.trunk/*actions/": true,
    "**/.trunk/*logs/": true,
    "**/.trunk/*notifications/": true,
    "**/.trunk/*out/": true,
    "**/.trunk/*plugins/": true
  },
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.enable": {
    "*": true,
    "markdown": true,
    "plaintext": false,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "hediet.vscode-drawio.resizeImages": null,
  "http.experimental.systemCertificatesV2": true,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.6)",
    "rgba(127,255,127, 0.6)",
    "rgba(255,127,255, 0.6)",
    "rgba(79,236,236, 0.6)"
  ],
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "java.compile.nullAnalysis.mode": "automatic",
  "java.configuration.detectJdksAtStart": false,
  "java.configuration.runtimes": [
    {{- $runtimes := list }}
    {{- /* SDKMAN: resolve latest installed Zulu 8 */ -}}
    {{- range $path := reverse (glob (joinPath .chezmoi.homeDir ".sdkman/candidates/java/8.*-zulu")) }}
      {{- $runtimes = append $runtimes (dict "name" "JavaSE-1.8" "path" $path) }}
      {{- break }}
    {{- end }}
    {{- /* Homebrew: resolve current openjdk@11 */ -}}
    {{- range $path := reverse (glob "/opt/homebrew/Cellar/openjdk@11/*/libexec/openjdk.jdk/Contents/Home") }}
      {{- $runtimes = append $runtimes (dict "name" "JavaSE-11" "path" $path) }}
      {{- break }}
    {{- end }}
    {{- /* VS Code extension: stable paths (no version in dir) */ -}}
    {{- $ext := joinPath .chezmoi.homeDir "Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk/java" }}
    {{- if stat (joinPath $ext "17") }}
      {{- $runtimes = append $runtimes (dict "name" "JavaSE-17" "path" (joinPath $ext "17")) }}
    {{- end }}
    {{- if stat (joinPath $ext "21") }}
      {{- $runtimes = append $runtimes (dict "name" "JavaSE-21" "path" (joinPath $ext "21")) }}
    {{- end }}
    {{- /* System JDK: resolve temurin-25 */ -}}
    {{- range $path := reverse (glob "/Library/Java/JavaVirtualMachines/temurin-25.jdk/Contents/Home") }}
      {{- $runtimes = append $runtimes (dict "name" "JavaSE-25" "path" $path "default" true) }}
      {{- break }}
    {{- end }}
    {{- range $i, $rt := $runtimes }}{{ if $i }},{{ end }}
    {
      "name": {{ get $rt "name" | toJson }},
      "path": {{ get $rt "path" | toJson }}{{ if hasKey $rt "default" }},
      "default": true{{ end }}
    }
    {{- end }}
  ],
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.debug.settings.hotCodeReplace": "auto",
  "java.import.gradle.home": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk/gradle/latest",
  "java.import.gradle.java.home": "/Library/Java/JavaVirtualMachines/temurin-25.jdk/Contents/Home",
  "java.maxConcurrentBuilds": 14,
  "java.sources.organizeImports.staticStarThreshold": 1,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "jdk.telemetry.enabled": false,
  "makefile.configureOnOpen": true,
  "mdb.mcp.server": "prompt",
  "metals.javaHome": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk/java/21",
  "mssql.connectionGroups": [
    {
      "id": "ROOT",
      "name": "ROOT"
    }
  ],
  "mssql.connections": [],
  "prettier.semi": false,
  "prettier.singleQuote": true,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "quarkus.tools.alwaysShowWelcomePage": false,
  "redhat.telemetry.enabled": true,
  "security.workspace.trust.untrustedFiles": "open",
  "sqldeveloper.datagrid.fontFamily": "Menlo, Monaco, 'Courier New', monospace",
  "sqldeveloper.sqlHistory.historyLimit": 500,
  "sqldeveloper.telemetry.enabled": false,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.enablePersistentSessions": false,
  "terminal.integrated.env.linux": {},
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1"
  },
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "zsh",
      "env": {
        "JAVA_HOME": "/Library/Java/JavaVirtualMachines/temurin-25.jdk/Contents/Home",
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk"
      }
    },
    "JavaSE-1.8 LTS": {
      "overrideName": true,
      "env": {
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk",
        "JAVA_HOME": "{{ .chezmoi.homeDir }}/.sdkman/candidates/java/8.0.462-zulu"
      },
      "path": "zsh"
    },
    "JavaSE-11 LTS": {
      "env": {
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk",
        "JAVA_HOME": "/opt/homebrew/Cellar/openjdk@11/11.0.30/libexec/openjdk.jdk/Contents/Home"
      },
      "overrideName": true,
      "path": "zsh"
    },
    "JavaSE-17 LTS": {
      "env": {
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk",
        "JAVA_HOME": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk/java/17"
      },
      "overrideName": true,
      "path": "zsh"
    },
    "JavaSE-21 LTS": {
      "env": {
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk",
        "JAVA_HOME": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk/java/21"
      },
      "overrideName": true,
      "path": "zsh"
    },
    "JavaSE-25 LTS": {
      "env": {
        "ZDOTDIR": "{{ .chezmoi.homeDir }}/Library/Application Support/Code/User/globalStorage/pleiades.java-extension-pack-jdk",
        "JAVA_HOME": "/Library/Java/JavaVirtualMachines/temurin-25.jdk/Contents/Home"
      },
      "overrideName": true,
      "path": "zsh"
    }
  },
  "terminal.integrated.tabs.hideCondition": "never",
  "thunder-client.requestLayout": "Top/Bottom",
  "trailing-spaces.backgroundColor": "rgba(255,0,0,0.1)",
  "trailing-spaces.includeEmptyLines": false,
  "trailing-spaces.trimOnSave": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vs-kubernetes": {
    "vs-kubernetes.crd-code-completion": "disabled"
