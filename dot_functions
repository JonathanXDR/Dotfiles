# ---------------------------- Shell & PATH Utils ---------------------------- #

log() {
  local level="$1"; shift
  local red green yellow blue gray reset

  if [[ -t 2 ]]; then
    red='\033[0;31m' green='\033[0;32m' yellow='\033[0;33m'
    blue='\033[0;34m' gray='\033[0;90m' reset='\033[0m'
  fi

  case "$level" in
    error|red)      printf "${red}Error:${reset}   %s\n" "$*" >&2 ;;
    success|green)  printf "${green}Success:${reset} %s\n" "$*" ;;
    warning|yellow) printf "${yellow}Warning:${reset} %s\n" "$*" >&2 ;;
    info|blue)      printf "${blue}Info:${reset}    %s\n" "$*" ;;
    debug)          [[ -n "${DEBUG:-}" ]] && printf "${gray}Debug:${reset}   %s\n" "$*" >&2 ;;
    *)              echo "$level" "$@" ;;
  esac
}

# Retry a command up to N times with a delay between attempts (from bash-it)
# Usage: retry <attempts> <delay_seconds> <command...>
retry() {
  local attempts="$1" delay="$2"; shift 2
  local i
  for (( i = 1; i <= attempts; i++ )); do
    if "$@"; then
      return 0
    fi
    (( i < attempts )) && sleep "$delay"
  done
  return 1
}

cmd:exists() {
  [[ $# -eq 1 ]] || {
    echo "Usage: cmd:exists <command>" >&2
    return 1
  }
  command -v "$1" &>/dev/null
}

# Run a command at most once per day (24 h), gated by a stamp file.
# Usage: run:daily <name> <command...>
run:daily() {
  local name="$1"; shift
  local stamp="${HOME}/.cache/daily/${name}"
  local -a fresh=( ${stamp}(N.mh-24) )
  (( ${#fresh} )) && return 0

  mkdir -p "${stamp:h}"
  "$@" && touch "$stamp"
}

# Safely prepend directories to PATH (skips missing or duplicate entries)
path:add() {
  local dir
  for dir in "$@"; do
    [[ -d "$dir" ]] && case ":$PATH:" in
      *":$dir:"*) ;;
      *) export PATH="$dir:$PATH" ;;
    esac
  done
}

# Safely append directories to PATH (skips missing or duplicate entries)
path:append() {
  local dir
  for dir in "$@"; do
    [[ -d "$dir" ]] && case ":$PATH:" in
      *":$dir:"*) ;;
      *) export PATH="$PATH:$dir" ;;
    esac
  done
}

# Create a new directory and enter it
mkd() {
  mkdir -p "$@" && cd "${@[-1]}" || return
}

# Change working directory to the top-most Finder window location
cdf() {
  cd "$(osascript -e 'tell app "Finder" to POSIX path of (insertion location as alias)')" || return
}

# ----------------------------- Files & Archives ----------------------------- #

# Create a .tar.gz archive, using `zopfli`, `pigz` or `gzip` for compression
targz() {
  local tmpFile="${1%/}.tar"
  tar -cvf "${tmpFile}" --exclude=".DS_Store" "${@}" || return 1

  local size
  size=$(stat -f"%z" "${tmpFile}" 2>/dev/null)

  local cmd=""
  if (( size < 52428800 )) && cmd:exists zopfli; then
    cmd="zopfli"
  elif cmd:exists pigz; then
    cmd="pigz"
  else
    cmd="gzip"
  fi

  log info "Compressing .tar ($((size / 1000)) kB) using \`${cmd}\`…"
  "${cmd}" -v "${tmpFile}" || return 1
  [[ -f "${tmpFile}" ]] && rm "${tmpFile}"

  local zippedSize
  zippedSize=$(stat -f"%z" "${tmpFile}.gz" 2>/dev/null)

  log success "${tmpFile}.gz ($((zippedSize / 1000)) kB) created successfully."
}

# Determine size of a file or total size of a directory
fs() {
  if (( $# )); then
    du -sh -- "$@"
  else
    du -sh .[^.]* ./*
  fi
}

# Create a data URL from a file
dataurl() {
  [[ -f "${1:-}" ]] || { log error "Usage: dataurl <file>"; return 1; }
  local mimeType
  mimeType=$(file -b --mime-type "$1")
  if [[ $mimeType == text/* ]]; then
    mimeType="${mimeType};charset=utf-8"
  fi
  echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')"
}

# Start an HTTP server from a directory, optionally specifying the port
server() {
  local port="${1:-8000}"
  { retry 5 1 curl -fs "http://localhost:${port}/" -o /dev/null && open "http://localhost:${port}/"; } &
  python3 -m http.server "${port}"
}

# Compare original and gzipped file size
gz() {
  [[ -f "${1:-}" ]] || { log error "Usage: gz <file>"; return 1; }
  local origsize
  origsize=$(wc -c < "$1")
  local gzipsize
  gzipsize=$(gzip -c "$1" | wc -c)
  local ratio
  ratio=$(echo "$gzipsize * 100 / $origsize" | bc -l)
  printf "orig: %d bytes\n" "$origsize"
  printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# Tree view with colors, ignoring common dirs, piped to less
trec() {
  tree -aC -I "${TREE_IGNORE}" --dirsfirst "$@" | less -FRNX
}

# Tree view without paging
tre() {
  tree -a -I "${TREE_IGNORE}" --dirsfirst "$@"
}

