# Git-powered colored diff (named gdiff to avoid shadowing /usr/bin/diff)
if cmd:exists git; then
  gdiff() {
    git diff --no-index --color-words "$@"
  }
fi

gdb() {
  if [[ -z "$1" ]]; then
    echo "Usage: gdb <branch>" >&2
    return 1
  fi
  git branch -d -- "$1" && git push origin :"$1"
}

gas() {
  if [[ -z "$1" ]]; then
    echo "Usage: gas <stash_index>" >&2
    return 1
  fi
  git stash apply "stash@{$1}"
}

grb() {
  if [[ -z "$1" ]]; then
    echo "Usage: grb <commit_count>" >&2
    return 1
  fi
  git rebase -i "HEAD~$1"
}

git:diff() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: git:diff <source_branch> <target_branch> [exclude_pattern]" >&2
    return 1
  fi

  local source_branch="$1"
  local target_branch="$2"
  local exclude_pattern="$3"

  local diff_args=("$source_branch...$target_branch")
  [[ -n "$exclude_pattern" ]] && diff_args+=(-- ":!$exclude_pattern")

  local file
  git diff --name-only "${diff_args[@]}" | while read -r file; do
    printf '\n%s:\n\n' "$file"
    git show "$target_branch:$file"
  done | pbcopy

  log success "Diff output copied to clipboard."
}

# --------------------------------- Chezmoi ---------------------------------- #

chezmoi:cleanup() {
  # Fix zsh completion insecure directory warnings (removes group-write permissions)
  if cmd:exists compaudit; then
    local dirs
    dirs="$(compaudit 2>/dev/null)"
    if [[ -n "$dirs" ]]; then
      echo "$dirs" | xargs chmod g-w 2>/dev/null
      log success "Fixed insecure zsh completion directories"
    fi
  fi

  # Remove stale GnuPG lock files
  local gpg_locks
  gpg_locks=("$HOME"/.gnupg/public-keys.d/pubring.db*.lock(N))
  if (( ${#gpg_locks[@]} )); then
    rm -f "${gpg_locks[@]}"
    log success "Removed ${#gpg_locks[@]} stale GnuPG lock file(s)"
  fi
}

chezmoi:sync() {
  # Sync template-managed files back to chezmoi source.
  # Files that only use {{ .chezmoi.homeDir }} are auto-synced (reverse substitution).
  # Files with secrets or other template vars are flagged for manual merge.
  cmd:exists chezmoi || { log error "chezmoi not found"; return 1; }

  local home_dir="${HOME}"
  local updated=0
  local skipped=0
  local src tmp rel

  while IFS= read -r target; do
    src="$(chezmoi source-path "$target" 2>/dev/null)" || continue

    [[ "$src" != *.tmpl ]] && continue
    [[ "$src" == *".chezmoi"* || "$src" == *"chezmoiscripts"* ]] && continue
    [[ ! -f "$target" ]] && continue

    # Reverse homeDir substitution on the target
    tmp="$(mktemp)"
    sed "s|${home_dir}|{{ .chezmoi.homeDir }}|g" "$target" > "$tmp"

    # Already in sync, skip
    if command diff -q "$src" "$tmp" >/dev/null 2>&1; then
      rm -f "$tmp"
      continue
    fi

    rel="${target#"$home_dir"/}"

    # Check for complex template syntax beyond .chezmoi.homeDir
    if sed 's/{{[^}]*\.chezmoi\.homeDir[^}]*}}//g' "$src" | grep -q '{{'; then
      log warning "Skipping ${rel} (has secrets/variables; use \`chezmoi merge ${target}\`)"
      (( skipped++ ))
      rm -f "$tmp"
      continue
    fi

    cp "$tmp" "$src"
    rm -f "$tmp"
    log success "${rel}"
    (( updated++ ))
  done < <(chezmoi managed --include=files --path-style=absolute)

  if (( updated + skipped == 0 )); then
    log info "All template-managed files are in sync."
  else
    (( updated > 0 )) && log info "Synced ${updated} file(s) back to source."
    (( skipped > 0 )) && log info "Skipped ${skipped} file(s) with complex templates."
  fi
}

