# Open current directory or given location in Finder
o() {
  open "${@:-.}"
}

# -------------------------- Networking, TLS & DNS --------------------------- #

# Run `dig` and display the most useful info
digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}

# Show all the names (CNs and SANs) listed in the SSL certificate for a given domain
getcertnames() {
  if [[ -z "${1}" ]]; then
    log error "No domain specified."
    return 1
  fi

  local domain="${1}"
  echo "Testing ${domain}…"
  echo ""

  local tmp
  tmp=$(printf 'GET / HTTP/1.0\nEOT\n' \
    | openssl s_client -connect "${domain}:443" -servername "${domain}" 2>&1)

  if [[ "${tmp}" = *"-----BEGIN CERTIFICATE-----"* ]]; then
    local certText
    certText=$(openssl x509 -text -certopt "no_aux, no_header, no_issuer, no_pubkey, \
      no_serial, no_sigdump, no_signame, no_validity, no_version" <<< "${tmp}")
    echo "Common Name:"
    echo ""
    grep "Subject:" <<< "${certText}" | sed -e "s/^.*CN=//" -e "s/\/emailAddress=.*//"
    echo ""
    echo "Subject Alternative Name(s):"
    echo ""
    grep -A 1 "Subject Alternative Name:" <<< "${certText}" \
      | sed -e "2s/DNS://g" -e "s/ //g" | tr "," "\n" | tail -n +2
    return 0
  else
    log error "Certificate not found."
    return 1
  fi
}

# Bundle corporate CA certificates into a single PEM file for NODE_EXTRA_CA_CERTS.
ssl:bundle() {
  local output="${1:-$HOME/.ssl/ca-bundle.pem}"
  mkdir -p "${output:h}"

  local tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT
  local cert_count=0

  IFS=',' read -rA keychain_certs <<< "${SSL_BUNDLE_KEYCHAIN_CERTS:-}"
  local cn
  for cn in "${keychain_certs[@]}"; do
    cn="${cn## }"; cn="${cn%% }"
    [[ -z "$cn" ]] && continue
    if security find-certificate -c "$cn" -p /Library/Keychains/System.keychain >> "$tmp" 2>/dev/null; then
      ((cert_count++))
    else
      log warning "$cn not found in system keychain"
    fi
  done

  IFS=',' read -rA remote_certs <<< "${SSL_BUNDLE_REMOTE_CERTS:-}"
  local -a curl_args=(-fsSL)
  [[ -n "${http_proxy:-}" ]] && curl_args+=(--proxy "$http_proxy")

  local url raw
  for url in "${remote_certs[@]}"; do
    url="${url## }"; url="${url%% }"
    [[ -z "$url" ]] && continue
    raw="$(mktemp)"

    if ! curl "${curl_args[@]}" -o "$raw" "$url"; then
      log warning "Failed to download ${url:t}"
      rm -f "$raw"
      continue
    fi

    # Auto-detect PEM vs DER format
    if openssl x509 -inform PEM -in "$raw" -outform PEM >> "$tmp" 2>/dev/null \
    || openssl x509 -inform DER -in "$raw" -outform PEM >> "$tmp" 2>/dev/null; then
      ((cert_count++))
    else
      log warning "${url:t} is not a valid PEM or DER certificate"
    fi
    rm -f "$raw"
  done

  if ((cert_count == 0)); then
    log error "No certificates were bundled"
    return 1
  fi

  mv "$tmp" "$output"
  log success "Bundled $cert_count certificate(s) into $output"
}

dns:change() {
  if (($# < 2)); then
    echo "Usage: dns:change <network service name> <DNS IPs separated by commas>" >&2
    return 1
  fi

  local network_service="$1"
  IFS=',' read -rA nameservers <<<"$2"

  sudo networksetup -setdnsservers "${network_service}" "Empty" "${nameservers[@]}"
}

# Cisco VPN binary path (set via CISCO_VPN_BIN in .exports)
_CISCO_VPN_BIN="${CISCO_VPN_BIN}"

_vpn:require-cli() {
  [[ -x "$_CISCO_VPN_BIN" ]] || {
    log warning "Cisco VPN CLI not found at $_CISCO_VPN_BIN"
    return 1
  }
}

vpn:state() {
  _vpn:require-cli || return 1
  "$_CISCO_VPN_BIN" state 2>/dev/null
}

vpn:hosts() {
  _vpn:require-cli || return 1
  "$_CISCO_VPN_BIN" hosts
}

vpn:is-connected() {
  vpn:state | grep -Eqi '^[[:space:]]*state[[:space:]]*:[[:space:]]*connected([[:space:]]|$)|^[[:space:]]*connected([[:space:]]|$)'
}

vpn:internet-ok() {
  curl -fsSIL --connect-timeout 3 --max-time 5 \
    https://www.google.com/generate_204 >/dev/null 2>&1
}

vpn:google-ok() {
  curl -fsSIL --connect-timeout 3 --max-time 5 \
    https://accounts.google.com >/dev/null 2>&1
}

vpn:google-broken() {
  vpn:internet-ok && ! vpn:google-ok
}

vpn:refresh() {
  _vpn:require-cli || return 1

  log info "Cisco state before refresh:"
  vpn:state || true

  log info "Disconnecting Cisco VPN..."
  "$_CISCO_VPN_BIN" disconnect >/dev/null 2>&1 || true
  sleep 3

  log info "Cisco state after disconnect:"
  vpn:state || true

  if ! vpn:google-broken; then
    log success "Broken TLS state appears cleared after disconnect."
    return 0
  fi

  log info "Attempting reconnect. MFA may be required..."
  "$_CISCO_VPN_BIN" connect
  local rc=$?

  log info "Cisco state after connect attempt:"
  vpn:state || true

  if [[ $rc -ne 0 ]]; then
    log warning "Connect command returned non-zero ($rc). Likely cancelled, MFA pending, or blocked."
  fi

  if vpn:google-broken; then
    log error "Drive is still broken after refresh."
    return 1
  fi

  log success "Drive works after refresh."
}

vpn:soft-refresh() {
  _vpn:require-cli || return 1

  log info "Cisco state before soft refresh:"
  vpn:state || true

  log info "Soft-refresh: disconnecting Cisco VPN..."
  "$_CISCO_VPN_BIN" disconnect >/dev/null 2>&1 || true
  sleep 3

  log info "Cisco state after soft refresh:"
  vpn:state || true

  if vpn:google-broken; then
    log warning "Drive still broken after disconnect-only soft refresh."
    return 1
  fi

  log success "Drive works again after disconnect-only soft refresh."
}

vpn:full-refresh() {
  local vpn_host="${1:-${VPN_DEFAULT_HOST}}"
  _vpn:require-cli || return 1

  if [[ -z "$vpn_host" ]]; then
    log warning "No VPN host specified. Pass one explicitly or set VPN_DEFAULT_HOST."
    return 1
  fi

  vpn:soft-refresh || true
  log info "Starting full reconnect to \"$vpn_host\". MFA may be required."
  "$_CISCO_VPN_BIN" connect "$vpn_host"
}

vpn:reset-filter() {
  log info "Restarting Cisco Secure Client UI to try resetting socket filter..."
  killall "Cisco Secure Client" 2>/dev/null || true
  sleep 2
  open -a "Cisco Secure Client"
}

proxy:compose-addr() {
  [[ $# -eq 3 ]] || return 1
  printf "%s://%s:%s" "$1" "$2" "$3"
}

proxy:set() {
  local proxy_protocol="${1:-${PROXY_PROTOCOL}}"
  local proxy_host="${2:-${PROXY_HOST}}"
  local proxy_port="${3:-${PROXY_PORT}}"
  local no_proxy="${4:-${NO_PROXY}}"

  if [[ -z "${proxy_protocol}" || -z "${proxy_host}" || -z "${proxy_port}" ]]; then
    echo "Usage: proxy:set <protocol> <host> <port> [no_proxy]" >&2
    echo "Or ensure PROXY_PROTOCOL, PROXY_HOST, and PROXY_PORT are set in ${HOME}/.exports" >&2
    return 1
  fi

  local proxy_addr
  proxy_addr="$(proxy:compose-addr "${proxy_protocol}" "${proxy_host}" "${proxy_port}")" || return 1

  export http_proxy="${proxy_addr}"
  export https_proxy="${proxy_addr}"
  export ftp_proxy="${proxy_addr}"
  export all_proxy="${proxy_addr}"
  export HTTP_PROXY="${proxy_addr}"
  export HTTPS_PROXY="${proxy_addr}"
  export FTP_PROXY="${proxy_addr}"
  export ALL_PROXY="${proxy_addr}"
  export PIP_PROXY="${proxy_addr}"
  export no_proxy="${no_proxy}"
  export NO_PROXY="${no_proxy}"
  export MAVEN_OPTS="-Dhttp.proxyHost=${proxy_host} -Dhttp.proxyPort=${proxy_port} -Dhttps.proxyHost=${proxy_host} -Dhttps.proxyPort=${proxy_port}"

  launchctl setenv HTTP_PROXY "${proxy_addr}" 2>/dev/null
  launchctl setenv HTTPS_PROXY "${proxy_addr}" 2>/dev/null
  launchctl setenv ALL_PROXY "${proxy_addr}" 2>/dev/null
  launchctl setenv NO_PROXY "${no_proxy}" 2>/dev/null
}

proxy:unset() {
  local var
  for var in http_proxy https_proxy ftp_proxy all_proxy \
             HTTP_PROXY HTTPS_PROXY FTP_PROXY ALL_PROXY \
             PIP_PROXY no_proxy NO_PROXY MAVEN_OPTS; do
    unset "$var"
  done

  for var in HTTP_PROXY HTTPS_PROXY ALL_PROXY NO_PROXY; do
    launchctl unsetenv "$var" 2>/dev/null
  done
}

proxy:probe() {
  local with_dns="${1:-}"

  if nc -z -w 3 "${PROXY_HOST}" "${PROXY_PORT}" &>/dev/null; then
    log info "Detected corporate network or reachable proxy, turning proxy on."
    proxy:set "${PROXY_PROTOCOL}" "${PROXY_HOST}" "${PROXY_PORT}" "${NO_PROXY}"

    if [[ "${with_dns}" == "dns" ]]; then
      if [[ -n "${PROXY_NETWORK_SERVICE}" && -n "${PROXY_DNS}" ]]; then
        dns:change "${PROXY_NETWORK_SERVICE}" "${PROXY_DNS}"
      else
        log warning "Skipping DNS change because PROXY_NETWORK_SERVICE or PROXY_DNS is not set."
      fi
    fi
  else
    log info "Detected normal network, turning proxy off."
    proxy:unset

    if [[ "${with_dns}" == "dns" ]]; then
      if [[ -n "${PROXY_NETWORK_SERVICE}" && -n "${NO_PROXY_DNS}" ]]; then
        dns:change "${PROXY_NETWORK_SERVICE}" "${NO_PROXY_DNS}"
      else
        log warning "Skipping DNS change because PROXY_NETWORK_SERVICE or NO_PROXY_DNS is not set."
      fi
    fi
  fi
}

proxyd:reload() {
  local label="local.proxy-watchd"
  local plist="${HOME}/Library/LaunchAgents/${label}.plist"

  [[ -f "${plist}" ]] || { log error "Plist not found: ${plist}"; return 1; }

  launchctl bootout "gui/$(id -u)/${label}" 2>/dev/null || true
  launchctl bootstrap "gui/$(id -u)" "${plist}"
  log success "Reloaded ${label}"
}

proxyd:status() {
  local label="local.proxy-watchd"
  local state_file="${HOME}/.cache/proxy-state"

  if launchctl print "gui/$(id -u)/${label}" &>/dev/null; then
    echo "Agent:  loaded (trigger-based, runs on network change)"
  else
    log warning "Agent not loaded"
  fi

  if [[ -f "${state_file}" ]]; then
    echo "Proxy:  $(< "${state_file}") (since $(stat -f '%Sm' "${state_file}"))"
  else
    log warning "State file not found"
  fi

  local _v
  echo ""
  echo "  Active (toggled by proxy:set/proxy:unset):"
  for _v in HTTP_PROXY HTTPS_PROXY ALL_PROXY FTP_PROXY PIP_PROXY NO_PROXY MAVEN_OPTS; do
    printf "    %-15s %s\n" "${_v}" "${(P)_v:-<unset>}"
  done

  echo ""
  echo "  Configuration (static, set by chezmoi):"
  for _v in NTLM_CREDENTIALS NODE_EXTRA_CA_CERTS NODE_TLS_REJECT_UNAUTHORIZED NODE_USE_ENV_PROXY SSL_BUNDLE_KEYCHAIN_CERTS SSL_BUNDLE_REMOTE_CERTS; do
    printf "    %-30s %s\n" "${_v}" "${(P)_v:-<unset>}"
  done
}

proxyd:log() {
  /usr/bin/log show --predicate 'eventMessage CONTAINS "proxy-watchd"' --last "${1:-5m}"
}

network:heal() {
  if vpn:google-broken; then
    log warning "Detected broken Drive TLS state. Trying soft Cisco refresh..."
    vpn:soft-refresh || {
      log warning "Soft refresh did not fix it. Trying Cisco UI restart..."
      vpn:reset-filter
      sleep 3

      if vpn:google-broken; then
        log warning "Drive still appears broken after UI restart. Run vpn:refresh manually if needed."
        return 1
      fi

      log success "Drive works again after Cisco UI restart."
    }
  fi
}

# ------------------------------------ SSH ----------------------------------- #

ssh:reagent() {
  local agent
  for agent in /tmp/ssh-*/agent.*; do
    export SSH_AUTH_SOCK="${agent}"
    if ssh-add -l &>/dev/null; then
      log success "Found working SSH Agent:"
      ssh-add -l
      return 0
    fi
  done
  log warning "Cannot find ssh agent. Maybe you should reconnect and forward it?"
  return 1
}

ssh:agent() {
  if pgrep -x ssh-agent &>/dev/null; then
    ssh:reagent &>/dev/null || eval "$(ssh-agent)" &>/dev/null
  else
    eval "$(ssh-agent)" &>/dev/null
  fi
}

# --------------------------------- Secrets ---------------------------------- #
#
# The macOS login keychain is the source of truth for all managed secrets.
# The tokens file on iCloud Drive (`$SECRETS_TOKENS_FILE`) mirrors the keychain
# in plain text so a fresh machine can re-import everything in one shot.
# Format: service:account:password (one per line, # comments allowed)
#
# Conventions for new entries:
#   service = the "Where" field (provider brand, e.g. GitHub, WakaTime)
#   account = the consumer (e.g. Zed) or the user identity (e.g. $USER)
#   label   = the secret type (e.g. personal_access_token, api_key)
#
# ---------------------------------------------------------------------------- #

_SECRETS_TOKENS_FILE="${SECRETS_TOKENS_FILE}"
_SECRETS_KEYCHAIN="$HOME/Library/Keychains/${SECRETS_KEYCHAIN_NAME:-dotfiles}.keychain-db"

# Map the configured lookup field to the matching `security` flag.
typeset -gA _SECRETS_FLAG_MAP=(name -l where -s kind -D comment -j)
_SECRETS_LOOKUP_FLAG="${_SECRETS_FLAG_MAP[${SECRETS_KEYCHAIN_LOOKUP_FIELD:-name}]:--l}"

# Create the managed keychain if missing and add it to the user search list.
# Empty SECRETS_KEYCHAIN_PASSWORD means the keychain inherits the login session
# unlock state — no extra prompt during use. A non-empty value sets a master
# password that must be supplied to unlock.
_secrets:ensure-keychain() {
  if [[ ! -f "$_SECRETS_KEYCHAIN" ]]; then
    local pw="${SECRETS_KEYCHAIN_PASSWORD:-}"
    security create-keychain -p "$pw" "${_SECRETS_KEYCHAIN%-db}" >/dev/null
    security set-keychain-settings -lut 0 "$_SECRETS_KEYCHAIN"
    security unlock-keychain -p "$pw" "$_SECRETS_KEYCHAIN"
  fi
  if ! security list-keychains -d user 2>/dev/null | grep -qF -- "$_SECRETS_KEYCHAIN"; then
    local -a paths=( ${(@f)"$(security list-keychains -d user | tr -d '"' | xargs -n1)"} )
    security list-keychains -d user -s "$_SECRETS_KEYCHAIN" "${paths[@]}"
  fi
}

_secrets:write-header() {
  printf '# id\taccount\twhere\tkind\tcomment\tpassword\n# Managed by secret:set. Import into the dotfiles keychain on new machines\n' > "$1"
}

# Ensure the tokens file exists with a header. Idempotent.
_secrets:ensure-tokens-file() {
  [[ -d "${_SECRETS_TOKENS_FILE:h}" ]] || mkdir -p "${_SECRETS_TOKENS_FILE:h}"
  [[ -f "$_SECRETS_TOKENS_FILE" ]] || _secrets:write-header "$_SECRETS_TOKENS_FILE"
}

# Stream "service<TAB>account" lines for each managed entry (skips # and blanks).
_secrets:each() {
  [[ -f "$_SECRETS_TOKENS_FILE" ]] || return 0
  awk -F'\t' '!/^[[:space:]]*#/ && NF>=2 {print $1 "\t" $2}' "$_SECRETS_TOKENS_FILE"
}

# Print the keychain "Name" attribute (the macOS Label / -l field).
_secrets:name() {
  security find-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" "$_SECRETS_KEYCHAIN" 2>&1 \
    | sed -nE 's/^[[:space:]]*0x00000007 <blob>="([^"]*)".*$/\1/p'
}

# Print the keychain "Where" attribute (the macOS Service / -s field).
_secrets:where() {
  security find-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" "$_SECRETS_KEYCHAIN" 2>&1 \
    | sed -nE 's/^[[:space:]]*"svce"<blob>="([^"]*)".*$/\1/p'
}

# Print the keychain "Kind" attribute (the macOS "desc" / -D field).
_secrets:kind() {
  security find-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" "$_SECRETS_KEYCHAIN" 2>&1 \
    | sed -nE 's/^[[:space:]]*"desc"<blob>="([^"]*)".*$/\1/p'
}

# Print the keychain "Comments" attribute (the macOS "icmt" / -j field).
_secrets:comment() {
  security find-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" "$_SECRETS_KEYCHAIN" 2>&1 \
    | sed -nE 's/^[[:space:]]*"icmt"<blob>="([^"]*)".*$/\1/p'
}

# Print the password of a managed secret. Empty stdout + non-zero on miss.
_secrets:password() {
  security find-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" -w "$_SECRETS_KEYCHAIN" 2>/dev/null
}

# Write a secret to the dotfiles keychain and register it in the tokens file.
# `id` populates the Label (-l, lookup key in default mode); `where` populates
# the Service (-s, the URL or other "where" metadata). The -A flag allows
# transparent reads from any application — required for chezmoi templates
# during apply, which would otherwise prompt for keychain confirmation.
# Usage: _secrets:install <id> <account> <where> <kind> <password> [comment]
_secrets:install() {
  local id="$1" acct="$2" where="$3" kind="$4" password="$5" comment="${6:-}"
  _secrets:ensure-keychain
  local -a flags=(-U -A -s "$where" -a "$acct" -l "$id" -D "$kind" -w "$password" "$_SECRETS_KEYCHAIN")
  [[ -n "$comment" ]] && flags=( -j "$comment" "${flags[@]}" )
  if ! security add-generic-password "${flags[@]}"; then
    log error "Failed to update keychain."
    return 1
  fi
  _secrets:ensure-tokens-file
  grep -qF -- "${id}"$'\t'"${acct}"$'\t' "$_SECRETS_TOKENS_FILE" 2>/dev/null \
    || print -r -- "${id}"$'\t'"${acct}"$'\t'"${where}"$'\t'"${kind}"$'\t'"${comment}"$'\t'"placeholder" >> "$_SECRETS_TOKENS_FILE"
}

# Add or update a secret in the dotfiles keychain, then sync to iCloud Drive.
# Password is read interactively; never echoed or stored in shell history.
# Refuses to create a duplicate (id, account) pair — uniqueness is enforced
# manually on the Label field since macOS only enforces it on Service.
# Usage: secret:set <id> <account> <where> <kind> [comment]
secret:set() {
  (( $# >= 4 && $# <= 5 )) || { echo "Usage: secret:set <id> <account> <where> <kind> [comment]" >&2; return 1; }
  local id="$1" account="$2" where="$3" kind="$4" comment="${5:-}" password

  if _secrets:password "$id" "$account" >/dev/null 2>&1; then
    log error "Already exists: $id / $account (use secret:rename to update)"
    return 1
  fi

  printf "Password for %s/%s: " "$id" "$account"
  read -rs password
  echo
  [[ -n "$password" ]] || { log error "Password cannot be empty."; return 1; }

  _secrets:install "$id" "$account" "$where" "$kind" "$password" "$comment" || return 1
  log success "Keychain updated: $id / $account ($kind)"
  secret:export
}

# Read a secret from the login keychain.
# Usage: secret:get <service> <account>
secret:get() {
  (( $# == 2 )) || { echo "Usage: secret:get <service> <account>" >&2; return 1; }
  _secrets:password "$1" "$2" || { log error "Not found: $1 / $2"; return 1; }
}

# Copy a secret to the macOS clipboard with auto-clear after TTL (default 30s).
# The clipboard is only cleared if it still holds the same value, so anything
# the user copies in the meantime is preserved. Override via SECRETS_CLIPBOARD_TTL.
# Usage: secret:copy <service> <account>
secret:copy() {
  (( $# == 2 )) || { echo "Usage: secret:copy <service> <account>" >&2; return 1; }
  local password snapshot ttl="${SECRETS_CLIPBOARD_TTL:-30}"

  password="$(_secrets:password "$1" "$2")" \
    || { log error "Not found: $1 / $2"; return 1; }

  printf '%s' "$password" | pbcopy
  snapshot=$(printf '%s' "$password" | shasum -a 256 | awk '{print $1}')
  unset password

  ( sleep "$ttl"
    [[ "$(pbpaste 2>/dev/null | shasum -a 256 | awk '{print $1}')" == "$snapshot" ]] \
      && printf '' | pbcopy
  ) &!

  log success "Copied $1 / $2 to clipboard. Auto-clears in ${ttl}s."
}

# Remove a secret from the login keychain, then sync to iCloud Drive.
# Usage: secret:remove <service> <account>
secret:remove() {
  (( $# == 2 )) || { echo "Usage: secret:remove <service> <account>" >&2; return 1; }
  if security delete-generic-password "$_SECRETS_LOOKUP_FLAG" "$1" -a "$2" "$_SECRETS_KEYCHAIN" >/dev/null 2>&1; then
    log success "Removed from keychain: $1 / $2"
  else
    log warning "Not found in keychain: $1 / $2"
  fi
  secret:export
}

# Move and/or update a managed secret. Source must exist; target (when
# different) must not, to prevent silent overwrites. Omit any of where/kind/
# comment to preserve current values.
# Usage: secret:rename <old_id> <old_account> <new_id> <new_account> [new_where] [new_kind] [new_comment]
secret:rename() {
  (( $# >= 4 && $# <= 7 )) || {
    echo "Usage: secret:rename <old_id> <old_account> <new_id> <new_account> [new_where] [new_kind] [new_comment]" >&2
    return 1
  }
  local old_id="$1" old_acct="$2" new_id="$3" new_acct="$4" password new_where new_kind new_comment
  local same_pair=0
  [[ "$old_id" == "$new_id" && "$old_acct" == "$new_acct" ]] && same_pair=1

  password="$(_secrets:password "$old_id" "$old_acct")" \
    || { log error "Not found: $old_id / $old_acct"; return 1; }

  if (( ! same_pair )) && _secrets:password "$new_id" "$new_acct" >/dev/null; then
    log error "Target already exists: $new_id / $new_acct"
    return 1
  fi

  new_where="${5:-$(_secrets:where "$old_id" "$old_acct")}"
  new_kind="${6:-$(_secrets:kind "$old_id" "$old_acct")}"
  [[ -n "$new_kind" ]] || new_kind="$new_id"
  new_comment="${7:-$(_secrets:comment "$old_id" "$old_acct")}"

  _secrets:install "$new_id" "$new_acct" "$new_where" "$new_kind" "$password" "$new_comment" || return 1
  (( same_pair )) || security delete-generic-password "$_SECRETS_LOOKUP_FLAG" "$old_id" -a "$old_acct" "$_SECRETS_KEYCHAIN" >/dev/null 2>&1

  log success "Renamed: $old_id / $old_acct -> $new_id / $new_acct ($new_kind)"
  secret:export
}

# List managed secrets as a sorted table (Name / Account / Kind / Used by / Where).
# Reads (service, account) pairs from the tokens file and queries the keychain
# for live Name/Kind/Comments, so output reflects live keychain state.
secret:list() {
  if [[ ! -f "$_SECRETS_TOKENS_FILE" ]]; then
    log warning "Tokens file not found: $_SECRETS_TOKENS_FILE"
    return 1
  fi

  {
    print -r -- $'ID\tACCOUNT\tKIND\tUSED BY\tWHERE'
    local id account where kind comment
    while IFS=$'\t' read -r id account; do
      where="$(_secrets:where "$id" "$account")"
      kind="$(_secrets:kind "$id" "$account")"
      comment="$(_secrets:comment "$id" "$account")"
      print -r -- "$id"$'\t'"$account"$'\t'"${kind:-(none)}"$'\t'"${comment:-(none)}"$'\t'"${where:-(none)}"
    done < <(_secrets:each) | sort -f
  } | column -t -s $'\t'
}

# Compare tokens-file passwords vs the live keychain. Reports drift, missing,
# and placeholder entries as a sorted table. Exits non-zero if any drift exists.
secret:check() {
  if [[ ! -f "$_SECRETS_TOKENS_FILE" ]]; then
    log warning "Tokens file not found: $_SECRETS_TOKENS_FILE"
    return 1
  fi

  local id acct where kind comment file_pw kc_pw state total=0 drift=0
  local -a rows

  while IFS=$'\t' read -r id acct where kind comment file_pw; do
    [[ -z "$id" || "$id" == \#* ]] && continue
    (( ++total ))
    kc_pw="$(_secrets:password "$id" "$acct")" || kc_pw=""
    if [[ -z "$kc_pw" ]]; then
      state="missing";     (( ++drift ))
    elif [[ "$file_pw" == placeholder ]]; then
      state="placeholder"; (( ++drift ))
    elif [[ "$file_pw" != "$kc_pw" ]]; then
      state="drift";       (( ++drift ))
    else
      state="ok"
    fi
    rows+=("$state"$'\t'"$id"$'\t'"$acct")
  done < "$_SECRETS_TOKENS_FILE"

  {
    print -r -- $'STATUS\tID\tACCOUNT'
    print -lr -- "${rows[@]}" | LC_ALL=C sort
  } | column -t -s $'\t'

  if (( drift > 0 )); then
    log warning "$drift / $total entries need attention. Run secret:export to sync."
    return 1
  fi
  log success "$total / $total entries in sync."
}

# Atomically rewrite the iCloud tokens file from current keychain values.
secret:export() {
  _secrets:ensure-tokens-file

  local tmp id account where kind comment password count=0
  tmp="$(mktemp)"
  trap 'rm -f "$tmp"' EXIT

  _secrets:write-header "$tmp"
  while IFS=$'\t' read -r id account; do
    password="$(_secrets:password "$id" "$account")" || true
    if [[ -n "$password" ]]; then
      where="$(_secrets:where "$id" "$account")"
      kind="$(_secrets:kind "$id" "$account")"
      comment="$(_secrets:comment "$id" "$account")"
      print -r -- "${id}"$'\t'"${account}"$'\t'"${where}"$'\t'"${kind}"$'\t'"${comment}"$'\t'"${password}" >> "$tmp"
      (( ++count ))
    else
      log warning "Skipping (not in keychain): $id / $account"
    fi
  done < <(_secrets:each)

  mv "$tmp" "$_SECRETS_TOKENS_FILE"
  trap - EXIT
  log success "Exported $count secret(s) to iCloud Drive."
}

# ----------------------- macOS System Tweaks & Utilities -------------------- #

sudo:touch-id() {
  local FILE='/etc/pam.d/sudo'
  local BACKUP
  BACKUP="$(mktemp /tmp/sudo.pam.backup.XXXXXX)"

  trap 'rm -f "$BACKUP"' EXIT

  log info "Backing up $FILE to $BACKUP…"
  sudo cp "$FILE" "$BACKUP" || { log error "Failed to create backup"; return 1; }

  # Only enable restore-on-error after a valid backup exists
  trap 'trap - ERR; log error "Error detected, restoring original file"; sudo cp "$BACKUP" "$FILE"; return 1' ERR

  if ! sudo grep -q '^# sudo: auth account password session' "$FILE"; then
    log error "Required marker comment not found in $FILE"
    return 1
  fi

  if ! sudo grep -qF 'auth       sufficient     pam_tid.so' "$FILE"; then
    log info "Inserting pam_tid line…"
    sudo sed -i '' '/^# sudo: auth account password session/a\
auth       sufficient     pam_tid.so
' "$FILE"
  else
    log info "pam_tid line already present, skipping insertion."
  fi

  trap - ERR
  log success "$FILE has been updated successfully."
}

gatekeeper:disable() {
  sudo spctl --master-disable
}

gatekeeper:enable() {
  sudo spctl --master-enable
}

hostname:get() {
  scutil --get ComputerName
}

hostname:set() {
  if [[ $# -ne 1 ]]; then
    echo "Usage: hostname:set <new-hostname>" >&2
    return 1
  fi

  local new_hostname="$1"

  sudo scutil --set ComputerName "$new_hostname"
  sudo scutil --set HostName "$new_hostname"
  sudo scutil --set LocalHostName "$new_hostname"

  log success "Hostname set to \"$new_hostname\". A restart may be required for all changes to take effect."
}

hostname:reset() {
  hostname:set "${DEFAULT_HOSTNAME}"
}

dock:reset() {
  defaults delete com.apple.dock
  killall Dock
  sleep 5

  IFS=',' read -rA apps <<< "${DOCK_APPS:-}"
  local app
  for app in "${apps[@]}"; do
    app="$(printf '%s' "$app" | xargs)"
    [[ -z "$app" ]] && continue
    defaults write com.apple.dock persistent-apps -array-add "<dict><key>tile-data</key><dict><key>file-data</key><dict><key>_CFURLString</key><string>/Applications/${app}.app</string><key>_CFURLStringType</key><integer>0</integer></dict></dict></dict>"
  done

  defaults write com.apple.dock mineffect -string "scale"
  defaults write com.apple.dock minimize-to-application -bool true
  defaults write com.apple.dock launchanim -bool false
  defaults write com.apple.dock show-recents -bool false
  defaults write com.apple.dock expose-group-apps -bool true

  killall Dock
}

system:setup() {
  gatekeeper:disable
  hostname:reset
  sudo:touch-id
}

system:shutdown() {
  sudo shutdown -h now
}

system:restart() {
  sudo shutdown -r now
}

system:sleep() {
  sudo shutdown -s now
}

# ---------------------------------- Docker ---------------------------------- #

docker:cleanup() {
  local ids
  if [[ $# -eq 0 ]]; then
    ids="$(docker ps -aq 2>/dev/null)" || true
    [[ -n "$ids" ]] && echo "$ids" | xargs docker stop 2>/dev/null && echo "$ids" | xargs docker rm 2>/dev/null || true
    ids="$(docker images -q 2>/dev/null)" || true
    [[ -n "$ids" ]] && echo "$ids" | xargs docker rmi 2>/dev/null || true
  else
    local exclude="$*"
    ids="$(docker ps -a --format '{{.ID}} {{.Names}}' 2>/dev/null | grep -vE "($exclude)" | awk '{print $1}')" || true
    [[ -n "$ids" ]] && echo "$ids" | xargs docker stop 2>/dev/null && echo "$ids" | xargs docker rm 2>/dev/null || true
    ids="$(docker images --format '{{.ID}} {{.Repository}}' 2>/dev/null | grep -vE "($exclude)" | awk '{print $1}')" || true
    [[ -n "$ids" ]] && echo "$ids" | xargs docker rmi 2>/dev/null || true
  fi
}

# ------------------------------- JS Ecosystem ------------------------------- #

# Source nvm.sh and completions (idempotent, safe to call multiple times).
nvm:init() {
  (( $+functions[nvm_find_nvmrc] )) && return 0
  unfunction nvm node npm npx 2>/dev/null

  if [[ -s "$NVM_DIR/nvm.sh" ]]; then
    source "$NVM_DIR/nvm.sh"
  elif [[ -s "/opt/homebrew/opt/nvm/nvm.sh" ]]; then
    source "/opt/homebrew/opt/nvm/nvm.sh"
  fi

  if [[ -s "$NVM_DIR/bash_completion" ]]; then
    source "$NVM_DIR/bash_completion"
  elif [[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ]]; then
    source "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
  fi
}

# Register lightweight stubs that defer nvm.sh sourcing until first use.
nvm:lazy() {
  local cmd
  for cmd in nvm node npm npx; do
    eval "${cmd}() { nvm:init; ${cmd} \"\$@\" }"
  done
}

node:works() {
  # Subshell catches zsh's "killed" message when macOS terminates an invalid binary
  (node --version >/dev/null 2>&1) 2>/dev/null
}

# Diagnose and repair a broken node binary (e.g., invalid code signature on macOS).
# Usage: nvm:heal [version]; defaults to nvm current
nvm:heal() {
  local version="${1:-$(nvm current 2>/dev/null)}"
  [[ -z "$version" || "$version" == "none" || "$version" == "system" ]] && return 1

  local node_bin="${NVM_DIR}/versions/node/${version}/bin/node"
  [[ ! -f "$node_bin" ]] && return 1

  # macOS fast path: ad-hoc re-sign (fixes Gatekeeper kills without redownloading)
  if [[ "$(uname)" == "Darwin" ]] && ! codesign -v "$node_bin" 2>/dev/null; then
    log info "Node $version has invalid code signature, attempting ad-hoc re-sign"
    if codesign --force --sign - "$node_bin" 2>/dev/null && node:works; then
      log success "Repaired $version via ad-hoc code signing"
      return 0
    fi
  fi

  # Slow path: clear cache and reinstall from scratch
  node:works && return 0
  log info "Reinstalling $version from scratch..."
  local os=${(L)$(uname -s)}
  rm -rf "${NVM_DIR}/.cache/bin/node-${version}-${os}-$(uname -m)" 2>/dev/null
  nvm uninstall "$version" 2>/dev/null
  nvm install "$version"
  node:works && { log success "Repaired $version via clean reinstall"; return 0; }
  log error "Could not repair $version"
  return 1
}

node:verify() {
  if ! node:works; then
    # Try healing the broken binary first (e.g., invalid code signature on macOS)
    nvm:heal 2>/dev/null || {
      log warning "node command failed, reinstalling LTS..."
      nvm install --lts --latest-npm
      nvm alias default 'lts/*'
      nvm use --lts
    }
  fi

  if ! node:works; then
    log warning "LTS node still broken, trying other installed versions..."
    local broken_version
    broken_version=$(nvm current 2>/dev/null)
    local version
    for version in ${(f)"$(nvm ls --no-colors 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | sort -t. -k1,1rn -k2,2rn -k3,3rn)"}; do
      [[ "$version" == "$broken_version" ]] && continue
      nvm use "$version" 2>/dev/null
      if node:works; then
        log success "Fell back to working version: $version"
        nvm alias default "$version"
        break
      fi
    done
  fi

  if ! node:works; then
    log error "No working node version found"
    return 1
  fi

  local node_version
  node_version=$(node --version)

  mkdir -p "${NPM_GLOBALS_LOCK_DIR}"
  local installed_globals_file="${NPM_GLOBALS_LOCK_DIR}/.npm.globals.${node_version}.lock"

  local needs_install=false
  if [[ ! -f "${installed_globals_file}" ]]; then
    needs_install=true
  elif [[ -f "${HOME}/.npm.globals" ]]; then
    local installed_count expected_count
    installed_count="$(wc -l < "${installed_globals_file}" 2>/dev/null || echo 0)"
    expected_count="$(grep -cvE '^#|^$' "${HOME}/.npm.globals" 2>/dev/null || echo 1)"
    (( installed_count < expected_count )) && needs_install=true
  fi

  if $needs_install; then
    globals:install
  fi
}

nvmrc:load() {
  if ! (( $+functions[nvm_find_nvmrc] )); then
    [[ -f .nvmrc || -f .node-version ]] || return 0
    nvm:init
  fi

  local nvmrc_path
  nvmrc_path="$(nvm_find_nvmrc)"

  if [[ -n "${nvmrc_path}" ]]; then
    local nvmrc_node_version
    nvmrc_node_version=$(nvm version "$(< "${nvmrc_path}")")

    if [[ "${nvmrc_node_version}" == "N/A" ]]; then
      nvm install
    elif [[ "${nvmrc_node_version}" != "$(nvm version)" ]]; then
      nvm use
    fi
  elif [[ -n "$(PWD=${OLDPWD} nvm_find_nvmrc)" ]] && [[ "$(nvm version)" != "$(nvm version default)" ]]; then
    log info "Reverting to nvm default version"
    nvm use default
  fi
}

conda:load() {
  # Auto-activate conda env when entering a directory with environment.yml
  if [[ -f "environment.yml" ]]; then
    local env_name
    env_name=$(grep '^name:' environment.yml | sed 's/^name:[[:space:]]*//')

    if [[ -n "$env_name" && "$CONDA_DEFAULT_ENV" != "$env_name" ]]; then
      conda activate "$env_name" 2>/dev/null || true
    fi
  elif [[ -n "$CONDA_DEFAULT_ENV" && "$CONDA_DEFAULT_ENV" != "base" ]]; then
    conda deactivate
  fi
}

nvm:update() {
  local previous_version
  previous_version=$(nvm current 2>/dev/null)

  if ! nvm install --lts --latest-npm &>/dev/null </dev/null; then
    log info "Skipping nvm update (could not reach remote)"
    return
  fi

  nvm alias default 'lts/*' &>/dev/null
  nvm use --lts &>/dev/null

  if ! node:works; then
    log warning "Newly installed LTS node is broken (binary killed or crashed)"
    if nvm:heal; then
      nvm alias default 'lts/*'
    elif [[ -n "$previous_version" && "$previous_version" != "none" && "$previous_version" != "system" ]]; then
      log info "Falling back to previous version: $previous_version"
      nvm use "$previous_version"
      nvm alias default "$previous_version"
    fi
  fi

  node:verify
}

bun:update() {
  local start_time elapsed tmplog
  tmplog=$(mktemp)
  trap 'rm -f "$tmplog"' EXIT
  start_time=$SECONDS

  bun upgrade &>"$tmplog" || true

  elapsed=$(( SECONDS - start_time ))
  if (( elapsed >= 5 )); then
    cat "$tmplog"
  fi
}

globals:install() {
  if [[ -f "$NPM_GLOBALS" ]]; then
    grep -vE '^#|^$' "$NPM_GLOBALS" | xargs npm install -g --force

    local node_version
    node_version=$(node --version)

    mkdir -p "${NPM_GLOBALS_LOCK_DIR}"
    local lock_file="${NPM_GLOBALS_LOCK_DIR}/.npm.globals.${node_version}.lock"
    grep -vE '^#|^$' "$NPM_GLOBALS" >"${lock_file}"

    log success "Global packages installed."
  else
    log warning ".npm.globals file not found."
  fi
}

ncu:update() {
  ncu -u
  rm -rf node_modules
  rm -f yarn.lock package-lock.json pnpm-lock.yaml bun.lock
  ni
}

# ------------------------------ Version Checks ------------------------------ #

pyenv:update() {
  local current latest
  current=$(pyenv version-name 2>/dev/null)
  latest=$(pyenv install --list 2>/dev/null \
    | awk '/^[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+$/ { v=$1 } END { if (v) print v }')

  [[ -z "$latest" ]] && { log info "Skipping pyenv update (could not fetch versions)"; return; }
  [[ "$current" == "$latest" ]] && return 0

  if ! pyenv install -s "$latest" &>/dev/null; then
    log info "Skipping pyenv update (install failed for ${latest})"
    return
  fi

  pyenv global "$latest"
  log success "Python updated: ${current} -> ${latest}"
}

brew:check() {
  local deprecated outdated

  deprecated=$(brew info --installed --json=v2 2>/dev/null \
    | jq -r '.formulae[] | select(.deprecated or .disabled)
      | "  \(.name) (\(.deprecation_reason // .disable_reason // "unknown"))"' 2>/dev/null)

  [[ -n "$deprecated" ]] && { log warning "Deprecated Homebrew packages:"; echo "$deprecated"; }

  outdated=$(brew outdated --quiet 2>/dev/null)
  [[ -n "$outdated" ]] || return 0

  log info "${#${(f)outdated}} outdated Homebrew package(s). Run 'brew upgrade' to update."
}

