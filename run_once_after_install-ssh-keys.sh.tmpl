#!/bin/bash
set -euo pipefail

ICLOUD_SSH="{{ .icloud_secrets }}/ssh"
TARGET_DIR="${HOME}/.ssh"

if [[ ! -d "$ICLOUD_SSH" ]]; then
  echo "iCloud SSH directory not found: $ICLOUD_SSH"
  echo "Skipping SSH key installation."
  exit 0
fi

# Ensure iCloud files are downloaded
if command -v brctl &>/dev/null; then
  brctl download "$ICLOUD_SSH" 2>/dev/null || true
  # Wait briefly for download
  sleep 2
fi

mkdir -p "$TARGET_DIR"

for file in "$ICLOUD_SSH"/*; do
  [[ -f "$file" ]] || continue
  filename="$(basename "$file")"
  cp "$file" "$TARGET_DIR/$filename"

  # Set permissions: private keys (no extension) get 600, public keys get 644
  if [[ "$filename" == *.pub ]]; then
    chmod 644 "$TARGET_DIR/$filename"
  elif [[ "$filename" == "config" ]] || [[ "$filename" == "known_hosts" ]]; then
    chmod 644 "$TARGET_DIR/$filename"
  else
    chmod 600 "$TARGET_DIR/$filename"
  fi

  echo "Installed SSH key: $filename"
done

echo "SSH keys installed to $TARGET_DIR"
