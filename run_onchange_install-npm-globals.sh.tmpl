#!/bin/bash
set -euo pipefail

# This script re-runs whenever dot_npm.globals changes.
# {{ include "dot_npm.globals" | sha256sum }}

NPM_GLOBALS="${HOME}/.npm.globals"

if [[ ! -f "$NPM_GLOBALS" ]]; then
  echo "npm globals file not found: $NPM_GLOBALS"
  exit 0
fi

# Ensure NVM is loaded
export NVM_DIR="${HOME}/.nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  source "$NVM_DIR/nvm.sh"
elif [[ -s "/opt/homebrew/opt/nvm/nvm.sh" ]]; then
  source "/opt/homebrew/opt/nvm/nvm.sh"
fi

if ! command -v npm &>/dev/null; then
  echo "npm not found, skipping global package installation."
  exit 0
fi

echo "Installing global npm packages..."
grep -vE '^#|^$' "$NPM_GLOBALS" | xargs npm install -g --force

echo "Global npm packages installed."
