// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{{- $ctx7_key := output "sh" "-c" "security find-generic-password -s 'context7' -a 'api-key' -w 2>/dev/null || true" | trim }}
{{- $github_pat := output "sh" "-c" "security find-generic-password -s 'github.com' -a 'zed-pat' -w 2>/dev/null || true" | trim }}
{
  "context_servers": {
{{- if ne $ctx7_key "" }}
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": {{ $ctx7_key | quote }}
      }
    }{{ if ne $github_pat "" }},{{ end }}
{{- end }}
{{- if ne $github_pat "" }}
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": {{ $github_pat | quote }}
      }
    }
{{- end }}
  },
  "inlay_hints": {
    "enabled": true,
    "show_value_hints": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50,
    "toggle_on_modifiers_press": {
      "control": false,
      "alt": false,
      "shift": false,
      "platform": false,
      "function": false
    }
  },
  "terminal": {
    "env": {
      "CW_NEW_SESSION": "1",
      "FIG_NEW_SESSION": "1",
      "Q_NEW_SESSION": "1"
    }
  },
  "minimap": {
    "show": "auto"
  },
  "file_types": {
    "markdown": [
      "*.mdx"
    ]
  },
  "auto_indent_on_paste": true,
  "use_on_type_format": true,
  "show_whitespaces": "all",
  "indent_guides": {
    "enabled": false,
    "line_width": 0,
    "active_line_width": 0,
    "coloring": "fixed",
    "background_coloring": "disabled"
  },
  "tab_size": 2,
  "preview_tabs": {
    "enabled": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Material Icon Theme"
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark Pro"
  }
}
