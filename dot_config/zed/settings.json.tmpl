// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "status_bar": {
    "show_active_file": true,
    "line_endings_button": true,
  },
  "show_whitespaces": "all",
  "format_on_save": "on",
  "completion_menu_item_kind": "symbol",
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "medium",
    },
    "sidebar_side": "right",
    "dock": "right",
  },
  "git_panel": {
    "commit_title_max_length": 72,
    "show_count_badge": true,
    "sort_by_path": true,
    "file_icons": true,
    "tree_view": true,
    "collapse_untracked_diff": true,
  },
  "outline_panel": {
    "dock": "left",
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "show_count_badge": true,
  },
  "project_panel": {
    "hide_root": true,
    "dock": "left",
    "diagnostic_badges": true,
    "git_status_indicator": true,
    "bold_folder_labels": true,
  },
  "use_system_window_tabs": true,
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": true,
  },
  "tabs": {
    "show_diagnostics": "all",
    "show_close_button": "hover",
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": true,
    "show_branch_name": true,
    "show_branch_status_icon": true,
  },
  "inlay_hints": {
    "show_background": true,
    "enabled": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
  },
  "tab_size": 2,
  "languages": {
    "Python": { "tab_size": 4 },
    "Java": { "tab_size": 4 },
    "Kotlin": { "tab_size": 4 },
    "Groovy": { "tab_size": 4 },
    "Scala": { "tab_size": 2 },
    "Clojure": { "tab_size": 2 },
    "C": { "tab_size": 4 },
    "C++": { "tab_size": 4 },
    "C#": { "tab_size": 4 },
    "Objective-C": { "tab_size": 4 },
    "Swift": { "tab_size": 4 },
    "Rust": { "tab_size": 4 },
    "Go": { "tab_size": 4, "hard_tabs": true },
    "Go Checksums": { "tab_size": 4, "hard_tabs": true },
    "Go Mod": { "tab_size": 4, "hard_tabs": true },
    "JavaScript": { "tab_size": 2 },
    "TypeScript": { "tab_size": 2 },
    "TSX": { "tab_size": 2 },
    "JSX": { "tab_size": 2 },
    "Vue.js": { "tab_size": 2 },
    "Svelte": { "tab_size": 2 },
    "Astro": { "tab_size": 2 },
    "HTML": { "tab_size": 2 },
    "CSS": { "tab_size": 2 },
    "SCSS": { "tab_size": 2 },
    "Less": { "tab_size": 2 },
    "JSON": { "tab_size": 2 },
    "JSONC": { "tab_size": 2 },
    "YAML": { "tab_size": 2 },
    "TOML": { "tab_size": 2 },
    "XML": { "tab_size": 2 },
    "Markdown": { "tab_size": 2 },
    "Ruby": { "tab_size": 2 },
    "PHP": { "tab_size": 4 },
    "Perl": { "tab_size": 4 },
    "Lua": { "tab_size": 2 },
    "Elixir": { "tab_size": 2 },
    "Erlang": { "tab_size": 4 },
    "Haskell": { "tab_size": 2 },
    "OCaml": { "tab_size": 2 },
    "F#": { "tab_size": 4 },
    "Dart": { "tab_size": 2 },
    "R": { "tab_size": 2 },
    "Julia": { "tab_size": 4 },
    "Zig": { "tab_size": 4 },
    "Nim": { "tab_size": 2 },
    "Crystal": { "tab_size": 2 },
    "Shell Script": { "tab_size": 2 },
    "Bash": { "tab_size": 2 },
    "Fish": { "tab_size": 2 },
    "PowerShell": { "tab_size": 4 },
    "SQL": { "tab_size": 2 },
    "GraphQL": { "tab_size": 2 },
    "Terraform": { "tab_size": 2 },
    "HCL": { "tab_size": 2 },
    "Dockerfile": { "tab_size": 2 },
    "Makefile": { "tab_size": 4, "hard_tabs": true },
    "CMake": { "tab_size": 2 },
    "Nix": { "tab_size": 2 },
    "Protocol Buffers": { "tab_size": 2 },
    "Solidity": { "tab_size": 4 },
  },
  "toolbar": {
    "code_actions": true,
  },
  "diff_view_style": "unified",
  "cli_default_open_behavior": "new_window",
  "context_servers": {
    "mcp-server-notion": {
      "enabled": true,
      "remote": false,
      "settings": {
        "notion_token": {{ includeTemplate "keychain" (list "Notion" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
    "mcp-server-firecrawl": {
      "enabled": true,
      "remote": false,
      "settings": {
        "firecrawl_api_key": {{ includeTemplate "keychain" (list "Firecrawl" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
    "mcp-server-supabase": {
      "enabled": true,
      "remote": false,
      "settings": {
        "supabase_access_token": {{ includeTemplate "keychain" (list "Supabase" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
    "GitLab (Swisscom)": {
      "command": "bunx",
      "args": ["@swisscom/red-gitlab-mcp@latest"],
      "env": {
        "GITLAB_API_URL": "https://code.swisscom.com/api/v4",
        "GITLAB_USE_OAUTH": "true",
        "GITLAB_OAUTH_CLIENT_ID": {{ includeTemplate "keychain" (list "GitLab MCP Client ID" "taarujo6" .keychain_name .keychain_lookup_field) | quote }},
        "GITLAB_OAUTH_CLIENT_SECRET": {{ includeTemplate "keychain" (list "GitLab MCP Client Secret" "taarujo6" .keychain_name .keychain_lookup_field) | quote }},
        "GITLAB_OAUTH_REDIRECT_URI": "http://127.0.0.1:8888/callback",
        "GITLAB_READ_ONLY_MODE": "true",
        "USE_PIPELINE": "true",
        "USE_MILESTONE": "true",
        "USE_GITLAB_WIKI": "true",
      },
    },
    "mcp-server-figma": {
      "enabled": true,
      "remote": false,
      "settings": {
        "figma_api_key": {{ includeTemplate "keychain" (list "Figma" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": {{ includeTemplate "keychain" (list "GitHub" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": {{ includeTemplate "keychain" (list "Context7" "jonathan" .keychain_name .keychain_lookup_field) | quote }},
      },
    },
  },
  "lsp": {
    "discord_presence": {
      "initialization_options": {
        "state": "Working in Zed",
        "details": null,
        "git_integration": false,
        "rules": {
          "mode": "blacklist",
          "paths": [
            "/Users/taarujo6/Developer/Git/SHIFT",
            "/Users/taarujo6/Developer/Git/Swisscom",
          ],
        },
      },
    },
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "codex-acp": {
      "default_config_options": {
        "mode": "full-access",
        "model": "gpt-5.5",
        "reasoning_effort": "high",
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Material Icon Theme",
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "system",
    "light": "GitHub Light",
    "dark": "GitHub Dark",
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    /* AI */
    "**/.claude",
  ],
}
