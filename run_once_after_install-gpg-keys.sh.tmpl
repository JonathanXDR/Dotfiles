#!/bin/bash
set -euo pipefail

ICLOUD_GPG="{{ .icloud_secrets }}/gnupg"
TARGET_DIR="${HOME}/.gnupg"

if [[ ! -d "$ICLOUD_GPG" ]]; then
  echo "iCloud GPG directory not found: $ICLOUD_GPG"
  echo "Skipping GPG key installation."
  exit 0
fi

# Ensure iCloud files are downloaded (recursive)
if command -v brctl &>/dev/null; then
  brctl download "$ICLOUD_GPG" 2>/dev/null || true
  sleep 2
fi

mkdir -p "$TARGET_DIR"
chmod 700 "$TARGET_DIR"

# Recursively copy all GPG files and subdirectories, excluding sockets and lock files
rsync -a \
  --exclude='S.gpg-agent*' \
  --exclude='S.keyboxd' \
  --exclude='S.scdaemon' \
  --exclude='*.lock' \
  --exclude='.DS_Store' \
  "$ICLOUD_GPG/" "$TARGET_DIR/"

# Fix permissions: directory 700, files 600
find "$TARGET_DIR" -type d -exec chmod 700 {} \;
find "$TARGET_DIR" -type f -exec chmod 600 {} \;

echo "GPG keys installed to $TARGET_DIR"
