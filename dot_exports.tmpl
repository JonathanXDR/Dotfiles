# ----------------------------- Editor & tools ------------------------------- #

export EDITOR={{ .editor | quote }}
export KUBE_EDITOR={{ .editor | quote }}

# Tool directories
export BUN_INSTALL="$HOME/.bun"
export NVM_DIR="$HOME/.nvm"
export SDKMAN_DIR="$HOME/.sdkman"
export NPM_GLOBALS="$HOME/.npm.globals"
export NPM_GLOBALS_LOCK_DIR="$HOME/.npm/_locks"

# Docker
export DOCKER_BUILDKIT=1
export COMPOSE_DOCKER_CLI_BUILD=1

{{ if eq .machine_type "work" -}}
export FORGEOPS_PATH={{ .forgeops_path | quote }}
export KUBECONFIG_PATH="$HOME/.kube"
{{ end -}}

# ------------------------------------ AI ------------------------------------ #

export CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1

# ---------------------------- Proxy configuration --------------------------- #

export ALWAYS_PROXY_PROBE={{ .always_proxy_probe | quote }}
export PROXY_PROTOCOL={{ .proxy_protocol | quote }}
export PROXY_HOST={{ .proxy_host | quote }}
export PROXY_PORT={{ .proxy_port | quote }}
export PROXY_DNS={{ .proxy_dns | quote }}
export NO_PROXY={{ .no_proxy | quote }}
export NO_PROXY_DNS={{ .no_proxy_dns | quote }}

# ----------------------------------- Auth ----------------------------------- #

{{ if eq .machine_type "work" -}}
{{- $ntlm := includeTemplate "keychain" (list "ntlm" "credentials") }}
export NTLM_CREDENTIALS={{ $ntlm | quote }}
{{ else -}}
export NTLM_CREDENTIALS=""
{{ end -}}

# ----------------------------------- Node ----------------------------------- #

# Reject unauthorized TLS/SSL certificates by default.
export NODE_TLS_REJECT_UNAUTHORIZED="${NODE_TLS_REJECT_UNAUTHORIZED:-1}"

# Let Node.js use HTTP(S)_PROXY env vars for fetch().
export NODE_USE_ENV_PROXY="${NODE_USE_ENV_PROXY:-0}"

# Extra CA certificates for corporate proxy
{{ if and (eq .machine_type "work") (ne .ssl_bundle_keychain_certs "") -}}
export NODE_EXTRA_CA_CERTS="${HOME}/.ssl/ca-bundle.pem"
{{ else -}}
export NODE_EXTRA_CA_CERTS=""
{{ end -}}

# Certificate CNs and URLs for bundling SSL certificates
export SSL_BUNDLE_KEYCHAIN_CERTS={{ .ssl_bundle_keychain_certs | quote }}
export SSL_BUNDLE_REMOTE_CERTS={{ .ssl_bundle_remote_certs | quote }}

# Enable persistent REPL history for `node`.
export NODE_REPL_HISTORY="${NODE_REPL_HISTORY:-$HOME/.node_history}"
export NODE_REPL_HISTORY_SIZE="${NODE_REPL_HISTORY_SIZE:-32768}"
export NODE_REPL_MODE="${NODE_REPL_MODE:-sloppy}"

# Force maximum (24-bit) color output in CLI tools that respect FORCE_COLOR.
export FORCE_COLOR=3

# ---------------------------------- Python ---------------------------------- #

export PYTHONIOENCODING="${PYTHONIOENCODING:-UTF-8}"

# ------------------------------ Locale & encoding --------------------------- #

export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ---------------------------------- History --------------------------------- #

HISTSIZE={{ .history_size }}
SAVEHIST=$HISTSIZE
HISTFILE="${HISTFILE:-$HOME/.zsh_history}"

setopt HIST_IGNORE_DUPS       # skip consecutive duplicates
setopt HIST_IGNORE_SPACE      # skip commands starting with space
setopt HIST_REDUCE_BLANKS     # trim superfluous whitespace
setopt SHARE_HISTORY          # share history across sessions
setopt APPEND_HISTORY         # append rather than overwrite

# Commands matching this pattern are dropped from both the in-memory list
# and $HISTFILE. HISTORY_IGNORE alone only filters the file write, leaving
# entries visible in `history` until shell exit; the zshaddhistory hook
# rejects them earlier so `history` never shows them.
HISTORY_IGNORE='({{ .history_ignore | join "*|" }}*)'
zshaddhistory() {
  emulate -L zsh -o extended_glob
  [[ "${1%$'\n'}" != ${~HISTORY_IGNORE} ]]
}

# ------------------------------ Pager & manuals ----------------------------- #

export MANPAGER="${MANPAGER:-less -X}"

# ------------------------------------ GPG ----------------------------------- #

# https://stackoverflow.com/a/42265848/96656
export GPG_TTY="$(tty)"

# ----------------------------- Default values ------------------------------ #

export DEFAULT_HOSTNAME={{ .default_hostname | quote }}

# Secrets tokens file path (used by secret:* functions)
export SECRETS_TOKENS_FILE={{ joinPath .icloud_secrets ".keychain/tokens" | quote }}

# Cisco VPN binary (used by vpn:* functions)
export CISCO_VPN_BIN={{ .cisco_vpn_bin | quote }}

# Tree view default ignore pattern (used by trec/tre functions)
export TREE_IGNORE={{ .tree_ignore | quote }}

# Directory basenames that rm() should permanently delete instead of trashing
export TRASH_SKIP={{ .trash_skip | join "|" | quote }}

# Dock apps for dock:reset (comma-separated)
export DOCK_APPS={{ .dock_apps | join "," | quote }}

# ----------------------------------- Paths ---------------------------------- #

# System-specific paths (appended to PATH in .zshrc)
export PATH_ADD="${PATH_ADD:-}"

# ----------------------------------- SSH ------------------------------------ #

export AUTOSTART_SSH_AGENT="${AUTOSTART_SSH_AGENT:-{{ .autostart_ssh_agent }}}"
