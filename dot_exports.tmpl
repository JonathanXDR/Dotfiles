#!/usr/bin/env zsh

# ---------------------------- Proxy configuration --------------------------- #

{{ if eq .machine_type "work" -}}
export ALWAYS_PROXY_PROBE="true"
export PROXY_PROTOCOL={{ .proxy_protocol | quote }}
export PROXY_HOST={{ .proxy_host | quote }}
export PROXY_PORT={{ .proxy_port | quote }}
export PROXY_DNS={{ .proxy_dns | quote }}
export NO_PROXY={{ .no_proxy | quote }}
export NO_PROXY_DNS={{ .no_proxy_dns | quote }}
{{ else -}}
export ALWAYS_PROXY_PROBE="false"
export PROXY_PROTOCOL="http"
export PROXY_HOST="localhost"
export PROXY_PORT="8080"
export PROXY_DNS=""
export NO_PROXY="localhost,127.0.0.1"
export NO_PROXY_DNS=""
{{ end -}}

# ----------------------------------- Auth ----------------------------------- #

{{ if eq .machine_type "work" -}}
export NTLM_CREDENTIALS={{ template "apw" list "ntlm" "credentials" | quote }}
{{ else -}}
export NTLM_CREDENTIALS=""
{{ end -}}

# ----------------------------------- Node ----------------------------------- #

# Reject unauthorized TLS/SSL certificates by default.
export NODE_TLS_REJECT_UNAUTHORIZED="${NODE_TLS_REJECT_UNAUTHORIZED:-1}"

# Let Node.js use HTTP(S)_PROXY env vars for fetch().
export NODE_USE_ENV_PROXY="${NODE_USE_ENV_PROXY:-0}"

# Extra CA certificates for corporate proxy
{{ if and (eq .machine_type "work") (ne .ssl_bundle_keychain_certs "") -}}
export NODE_EXTRA_CA_CERTS="${HOME}/.ssl/ca-bundle.pem"
{{ else -}}
export NODE_EXTRA_CA_CERTS=""
{{ end -}}

# Certificate CNs and URLs for bundling SSL certificates
export SSL_BUNDLE_KEYCHAIN_CERTS={{ .ssl_bundle_keychain_certs | quote }}
export SSL_BUNDLE_REMOTE_CERTS={{ .ssl_bundle_remote_certs | quote }}

# Enable persistent REPL history for `node`.
export NODE_REPL_HISTORY="${NODE_REPL_HISTORY:-$HOME/.node_history}"

# Allow 32³ entries; the default is 1000.
export NODE_REPL_HISTORY_SIZE="${NODE_REPL_HISTORY_SIZE:-32768}"

# Use sloppy mode by default, matching web browsers.
export NODE_REPL_MODE="${NODE_REPL_MODE:-sloppy}"

# ---------------------------------- Python ---------------------------------- #

# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr.
export PYTHONIOENCODING="${PYTHONIOENCODING:-UTF-8}"

# ------------------------------ Locale & encoding --------------------------- #

# Prefer US English and use UTF-8.
export LANG="${LANG:-en_US.UTF-8}"
export LC_ALL="${LC_ALL:-en_US.UTF-8}"

# ---------------------------------- History --------------------------------- #

# Increase history size. Allow 32³ entries; the default is lower.
export HISTSIZE="${HISTSIZE:-32768}"
export HISTFILESIZE="${HISTFILESIZE:-$HISTSIZE}"
# Omit duplicates and commands that begin with a space from history (bash-only).
export HISTCONTROL="${HISTCONTROL:-ignoreboth}"

# ------------------------------ Pager & manuals ----------------------------- #

# Don't clear the screen after quitting a manual page.
export MANPAGER="${MANPAGER:-less -X}"

# ------------------------------------ GPG ----------------------------------- #

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
# shellcheck disable=SC2155
export GPG_TTY="$(tty)"

# ------------------------------ macOS quirks -------------------------------- #

# Hide the "default interactive shell is now zsh" warning on macOS.
export BASH_SILENCE_DEPRECATION_WARNING="${BASH_SILENCE_DEPRECATION_WARNING:-1}"

# --------------------------- Default user prompt ---------------------------- #

# Set our username so prompts that respect DEFAULT_USER can hide it.
export DEFAULT_USER="${DEFAULT_USER:-$USER}"

# ----------------------------------- Paths ---------------------------------- #

# Add more things to PATH only specific to this specific system
# This will be automatically added to PATH by .paths
export PATH_ADD="${PATH_ADD:-}"

# ----------------------------------- SSH ------------------------------------ #

# This seems to cause some error with the zsh syntax highlighting
# AUTOSTART_SSH_AGENT="true"
