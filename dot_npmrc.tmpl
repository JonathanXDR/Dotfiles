registry=https://registry.npmjs.org/
{{- $npm_token := includeTemplate "keychain" (list "npm" "jonathan" .keychain_name .keychain_lookup_field) }}
{{- if ne $npm_token "" }}
//registry.npmjs.org/:_authToken={{ $npm_token }}
{{- end }}
{{- if eq .machine_type "work" }}
{{- $swisscom := includeTemplate "keychain" (list "JFrog Artifactory (General)" "taarujo6" .keychain_name .keychain_lookup_field) }}
{{- if ne $swisscom "" }}
//bin.swisscom.com/artifactory/api/npm/:_authToken={{ $swisscom }}
{{- end }}
{{- $apps := includeTemplate "keychain" (list "JFrog Artifactory (Apps Team)" "taarujo6" .keychain_name .keychain_lookup_field) }}
{{- if ne $apps "" }}
//bin.swisscom.com/artifactory/api/npm/apps-team-npm-virtual/:_authToken={{ $apps }}
{{- end }}
{{- end }}
