#!/bin/bash
set -euo pipefail

ICLOUD_ENV="{{ .icloud_secrets }}/.env"
TARGET="${HOME}/.env"

if [[ ! -f "$ICLOUD_ENV" ]]; then
  echo "iCloud .env file not found: $ICLOUD_ENV"
  echo "Skipping .env installation."
  exit 0
fi

# Ensure iCloud file is downloaded
if command -v brctl &>/dev/null; then
  brctl download "$ICLOUD_ENV" 2>/dev/null || true
  sleep 2
fi

cp "$ICLOUD_ENV" "$TARGET"
chmod 600 "$TARGET"

echo "Environment file installed to $TARGET"
