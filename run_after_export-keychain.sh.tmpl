#!/bin/bash
set -euo pipefail

# Re-export all managed secrets from the login keychain to the iCloud Drive
# tokens file after every chezmoi apply. This ensures the backup stays in sync
# even if secrets were updated via `chezmoi secret keyring set`, Keychain
# Access.app, or any other method that bypasses `secret:set`.

TOKENS_FILE="{{ .icloud_secrets }}/keychain/tokens"

# Nothing to export if no tokens file exists yet
[[ -f "$TOKENS_FILE" ]] || exit 0

tmpfile="$(mktemp)"
trap 'rm -f "$tmpfile"' EXIT

# Preserve header comments
grep '^#' "$TOKENS_FILE" > "$tmpfile" 2>/dev/null || true

changed=false

while IFS=: read -r service account old_password; do
  [[ -z "$service" || "$service" == \#* ]] && continue

  password="$(security find-generic-password -s "$service" -a "$account" -w 2>/dev/null)" || true
  if [[ -n "$password" ]]; then
    echo "$service:$account:$password" >> "$tmpfile"
    [[ "$password" != "$old_password" ]] && changed=true
  else
    # Keep the old entry if the keychain lookup fails (e.g. entry was removed)
    # secret:remove handles cleanup; this is just a safety net
    echo "$service:$account:$old_password" >> "$tmpfile"
  fi
done < "$TOKENS_FILE"

if [[ "$changed" == true ]]; then
  mv "$tmpfile" "$TOKENS_FILE"
  echo "Keychain → iCloud Drive: tokens file updated."
else
  rm -f "$tmpfile"
fi
